{
  "name": "playwright-regression-poc",
  "version": "1.0.0",
  "private": true,
  "description": "Docker-based Playwright regression testing proof of concept",
  "scripts": {
    "test:smoke": "playwright test tests/example.spec.ts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report playwright-report --host 0.0.0.0 --port 9323"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0"
  }
}
